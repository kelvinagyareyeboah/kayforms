{
  "name": "@kayforms/angular",
  "version": "0.1.0",
  "description": "Angular Signals adapter for Kayforms reactive form library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kayforms/core": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0"
  },
  "devDependencies": {
    "@angular/core": "^16.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0"
  },
  "sideEffects": false,
  "license": "MIT"
}
